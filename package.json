{
  "name": "schichtplan-ical",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot server/index.ts",
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd client && bunx vite build",
    "build:server": "bun build server/index.ts --outdir dist --target bun",
    "db:generate": "bunx drizzle-kit generate",
    "db:push": "bunx drizzle-kit push",
    "start": "bun run server/index.ts"
  },
  "dependencies": {
    "@hono/oidc-auth": "^1.8.3",
    "@hono/zod-validator": "^0.8.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.5",
    "jose": "^6.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "drizzle-kit": "^0.31.3",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  }
}
